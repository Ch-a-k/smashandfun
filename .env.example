# Supabase Configuration
# Get these values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Site Verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Meta (Facebook) Pixel
NEXT_PUBLIC_FB_PIXEL_ID=

# TikTok Pixel
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Email Configuration (Nodemailer / SMTP / Zoho)
# Supported aliases:
# SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASSWORD / SMTP_SECURE
# ZOHO_HOST / ZOHO_PORT / ZOHO_USER / ZOHO_PASS
# EMAIL_HOST / EMAIL_PORT / EMAIL_USER / EMAIL_PASS
# Optional routing:
# EMAIL_FROM / EMAIL_TO / EMAIL_RECEIVER / EMAIL_CC
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=
EMAIL_FROM=
EMAIL_TO=
EMAIL_RECEIVER=
EMAIL_CC=

# Legacy aliases kept for compatibility
ZOHO_HOST=
ZOHO_PORT=
ZOHO_USER=
ZOHO_PASS=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=

# Google Ads API (admin + scripts/google-ads-auth.js — не коммить секреты)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# PayU Payment Gateway (if using)
PAYU_CLIENT_ID=
PAYU_CLIENT_SECRET=
PAYU_POS_ID=
PAYU_MD5_KEY=
PAYU_NOTIFY_URL=
PAYU_CONTINUE_URL=

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
